{
  "$schema": "Design system for docproc // edu — framed minimalist SaaS shell",
  "meta": {
    "purpose": "Authoritative design and UX system for docproc. Defines layout, motion, navigation, visual hierarchy, and interaction behavior.",
    "themes": ["light", "dark"],
    "aesthetic": "Modern minimalist SaaS. Centered canvas. Soft depth. High clarity. Structured but fluid."
  },

  "designPrinciples": {
    "centeredCanvas": "Primary content lives in a framed container centered in viewport.",
    "calmDensity": "Information-dense but breathable through spacing.",
    "softDepth": "Layered surfaces and subtle shadow. No harsh borders.",
    "controlledAccent": "One primary accent. Semantic colors only for state.",
    "fluidNavigation": "Transitions feel continuous, never abrupt.",
    "professionalTone": "Confident and refined. Never playful or loud."
  },

  "layoutSystem": {
    "shell": {
      "structure": "Framed app container inside viewport",
      "appMaxWidth": "min(90vw, 120rem)",
      "appHeight": "min(92vh, 80rem)",
      "appRadius": "1rem",
      "outerPadding": "clamp(1rem, 2vw, 2rem)",
      "shadow": "soft elevated container shadow in light mode; none in dark"
    },

    "topBar": {
      "height": "clamp(3.5rem, 4vw, 4.5rem)",
      "horizontalPadding": "clamp(1rem, 2vw, 2rem)",
      "layout": "Left: branding + breadcrumbs. Center: search. Right: actions + avatar."
    },

    "mainArea": {
      "structure": "Single primary content column",
      "contentMaxWidth": "min(80ch, 65vw)",
      "contentCentering": "margin-inline auto",
      "verticalSpacing": "3rem between sections"
    },

    "sidePanels": {
      "type": "Overlay slide-in panel",
      "width": "min(32rem, 40vw)",
      "activation": "Triggered by tabs or contextual actions",
      "animation": "TranslateX + opacity"
    }
  },

  "spacingScale": {
    "unit": "4px grid (converted to rem)",
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem"
  },

  "typography": {
    "fontFamily": "Inter, SF Pro, or Plus Jakarta Sans",
    "monospace": "JetBrains Mono",
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.5rem",
      "2xl": "2rem"
    },
    "weights": {
      "regular": "400–500",
      "medium": "500–600",
      "bold": "600–700"
    },
    "lineHeight": {
      "body": "1.6",
      "heading": "1.2"
    }
  },

  "colorSystem": {
    "accentStrategy": "Single blue accent for actions and navigation. Semantic colors for success/error only.",

    "light": {
      "backgroundViewport": "#EDEDED",
      "appSurface": "#FFFFFF",
      "surfaceMuted": "#F6F6F7",
      "surfaceInteractive": "#F2F2F4",
      "textPrimary": "#111111",
      "textSecondary": "#6B6B6B",
      "textTertiary": "#9B9B9B",
      "accentPrimary": "#2563EB",
      "success": "#16A34A",
      "error": "#DC2626",
      "borderSubtle": "rgba(0,0,0,0.06)",
      "shadowApp": "0 20px 60px rgba(0,0,0,0.08)"
    },

    "dark": {
      "backgroundViewport": "#0F0F10",
      "appSurface": "#18181A",
      "surfaceMuted": "#1F1F22",
      "surfaceInteractive": "#26262A",
      "textPrimary": "#E5E5E5",
      "textSecondary": "#A1A1AA",
      "textTertiary": "#6B7280",
      "accentPrimary": "#7C9CFF",
      "success": "#22C55E",
      "error": "#EF4444",
      "borderSubtle": "rgba(255,255,255,0.08)",
      "shadowApp": "none"
    }
  },

  "navigationSystem": {
    "primary": {
      "type": "Left vertical navigation rail (icon + label)",
      "width": "clamp(4rem, 5vw, 5rem)",
      "activeState": "Soft background highlight + accent indicator bar",
      "hover": "SurfaceInteractive background"
    },

    "secondaryTabs": {
      "location": "Below top bar within content header",
      "style": "Text tabs with sliding underline",
      "indicatorHeight": "2px",
      "animation": "Slide using transform with 240ms easing",
      "usage": "Switch between Chat, Notes, Flashcards, Tests"
    },

    "breadcrumbs": {
      "style": "Small, muted text in top bar",
      "separator": "/"
    }
  },

  "motionSystem": {
    "philosophy": "Smooth, premium, understated.",
    "durations": {
      "micro": "120ms",
      "standard": "240ms",
      "panel": "280ms",
      "overlay": "320ms"
    },
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)",
    "patterns": {
      "pageTransition": "Fade + slight Y translation",
      "panelSlide": "TranslateX + opacity",
      "tabSwitch": "Underline slide + content crossfade",
      "hover": "Background fade only",
      "cardLift": "Subtle translateY(-2px) + shadow increase"
    }
  },

  "components": {
    "cards": {
      "radius": "0.75rem",
      "padding": "1.5rem",
      "background": "appSurface",
      "border": "1px solid borderSubtle",
      "hover": "Optional subtle lift"
    },

    "buttons": {
      "primary": {
        "background": "accentPrimary",
        "color": "white",
        "radius": "0.5rem",
        "padding": "0.5rem 1rem"
      },
      "secondary": {
        "background": "surfaceInteractive",
        "color": "textPrimary",
        "radius": "0.5rem"
      },
      "ghost": {
        "background": "transparent",
        "color": "textSecondary"
      }
    },

    "inputs": {
      "background": "surfaceInteractive",
      "border": "1px solid borderSubtle",
      "focus": "Accent border + subtle glow",
      "radius": "0.5rem"
    },

    "tables": {
      "headers": "Medium weight text",
      "rowHover": "SurfaceMuted background",
      "alignment": "Text left, numbers right"
    },

    "chat": {
      "messageStyle": "Flat blocks, no bubbles",
      "assistantAccent": "Thin accent left border",
      "actions": "Appear on hover"
    },

    "flashcards": {
      "cardWidth": "min(42rem, 60vw)",
      "radius": "1rem",
      "flipAnimation": "rotateY 400ms",
      "progressBar": "2px accent line at top"
    }
  },

  "uxPatterns": {
    "emptyStates": "Minimal illustration or icon + concise instruction + one primary CTA.",
    "loadingStates": "Skeleton shimmer matching layout.",
    "modals": "Centered overlay with background blur.",
    "notifications": "Top-right ephemeral toast.",
    "processingState": "Animated status dot or subtle shimmer."
  },

  "accessibility": {
    "focusRing": "2px accent outline with offset",
    "contrast": "WCAG AA minimum",
    "keyboardNavigation": "All tabs and panels keyboard accessible"
  },

  "usageNotesForAI": [
    "Use tokens, not raw hex.",
    "Do not create multiple competing accent colors.",
    "Avoid heavy gradients.",
    "Keep transitions smooth and consistent.",
    "Prefer centered content over multi-column layouts.",
    "Avoid cluttering the viewport edges."
  ]
}