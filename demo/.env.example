# Copy to .env and fill in. Used by docker compose (api + worker) when you run from demo/.
# You can also copy the repo root .env here: cp ../.env .env

# ---------------------------------------------------------------------------
# Azure OpenAI (docproc CLI in worker: extraction + vision/LLM refine)
# ---------------------------------------------------------------------------
DOCPROC_PRIMARY_AI=azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Azure AI Vision (optional) — image extraction in docproc CLI
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# ---------------------------------------------------------------------------
# Alternative: OpenAI (set DOCPROC_PRIMARY_AI=openai or leave unset and set OPENAI_API_KEY)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
